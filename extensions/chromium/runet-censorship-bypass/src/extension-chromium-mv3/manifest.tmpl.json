{
  "manifest_version": 3,

  "name": "__MSG_extName__",
  "default_locale": "ru",
  "description": "__MSG_extDesc__",
  "version": "0.0.${storeVersion}",
  "version_name": "0.0.${version}",
  "icons": {
    "128": "icons/default-128.png"
  },
  "author": "anticensority+owners@googlegroups.com",

  "permissions": [
      "proxy"
    , "alarms"
    , "storage"
    , "notifications"
    , "offscreen"
    , "webRequest"
    , "webRequestAuthProvider"
    , "activeTab"
  ],
  "host_permissions": [
      "https://e.cen.rodeo:8443/*"
    , "https://antizapret.prostovpn.org/*"
    , "https://antizapret.prostovpn.org:8443/*"
    , "https://antizapret.prostovpn.org:18443/*"
    , "https://anticensority.github.io/*"
    , "https://raw.githubusercontent.com/*"
    , "<all_urls>"
  ],

  "background": {
    "service_worker": "background/service-worker.js"
  },

  "action": {
    "default_icon": {
      "128": "icons/default-128.png"
    },
    "default_title": "__MSG_extName__",
    "default_popup": "pages/popup/index.html"
  },
  "options_ui": {
     "page": "pages/options/index.html",
     "open_in_tab": true
   }

}
