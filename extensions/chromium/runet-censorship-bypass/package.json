{
  "name": "runet-censorship-bypass",
  "version": "0.0.19",
  "description": "Development tools for chromium extension",
  "scripts": {
    "lint": "eslint ./src/**/*.js --ignore-pattern vendor",
    "lint:mv3": "eslint ./src/extension-chromium-mv3/**/*.js",
    "gulp": "gulp",
    "build:mv2": "node ./node_modules/gulp/bin/gulp.js buildAll",
    "build:mv3": "node ./node_modules/gulp/bin/gulp.js buildChromiumMv3",
    "test": "mocha --recursive ./src/**/test/*",
    "test:legacy": "mocha --recursive ./src/extension-common/test/*",
    "test:mv3": "mocha --recursive ./src/extension-chromium-mv3/test/*",
    "test:pac": "mocha ./src/extension-chromium-mv3/test/pac-regression.js",
    "verify:mv3": "npm run lint:mv3 && npm run test:mv3 && npm run build:mv3",
    "verify": "npm test && npm run lint:mv3 && npm run build:mv2 && npm run build:mv3",
    "subpages": "npm --prefix ./src/extension-common/pages/options run build",
    "subpages:dev": "npm --prefix ./src/extension-common/pages/options run build:dev:nocomp",
    "start": "npm run release",
    "release": "npm run subpages && npx gulp -- buildAll"
  },
  "author": "Ilya Ig. Petrov",
  "license": "GPLv3",
  "devDependencies": {
    "chai": "^4.3.0",
    "eslint": "^7.19.0",
    "eslint-config-google": "^0.14.0",
    "gulp-changed": "^4.0.2",
    "mocha": "^8.2.1",
    "sinon-chrome": "^3.0.1",
    "symlink-to": "^0.0.4"
  },
  "dependencies": {
    "del": "^6.0.0",
    "gulp": "^4.0.2",
    "plugin-error": "^1.0.1",
    "through2": "^4.0.2",
    "tldts": "7.4.8"
  }
}
